#!/usr/bin/env bash
# Repository prepare-commit-msg hook (mirror for contributors)
# Prepend an emoji based on Conventional Commit prefix or branch name.

COMMIT_MSG_FILE="$1"
CONTEXT="$2"

# Do not modify merge, squash, or revert messages
if [[ "$CONTEXT" == "merge" || "$CONTEXT" == "squash" || "$CONTEXT" == "revert" ]]; then
  exit 0
fi

# Read first non-empty line of commit message
FIRST_LINE=$(sed -n '1p' "$COMMIT_MSG_FILE" | sed 's/^\s*//;s/\s*$//')

# If file already starts with one of our emojis, do nothing
if echo "$FIRST_LINE" | grep -qE '^(✨|🐛|📝|🔧|♻️|✅|💄|🚀|🔥|🐧|🔒) '; then
  exit 0
fi

# Prefer Conventional Commit prefix (type: or type(scope):)
TYPE_PREFIX=$(echo "$FIRST_LINE" | sed -E 's/^([a-z]+)(\([^)]+\))?:.*$/\1/' | tr '[:upper:]' '[:lower:]')

EMOJI="✨"
case "$TYPE_PREFIX" in
  feat) EMOJI="✨";;
  fix) EMOJI="🐛";;
  docs) EMOJI="📝";;
  chore) EMOJI="🔧";;
  refactor) EMOJI="♻️";;
  test) EMOJI="✅";;
  style) EMOJI="💄";;
  perf) EMOJI="🚀";;
  ci) EMOJI="🔒";;
  build) EMOJI="🐧";;
  *)
    # Fallback: try branch name
    BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    case "$BRANCH" in
      feat/*|feature/*) EMOJI="✨";;
      fix/*|bugfix/*) EMOJI="🐛";;
      docs/*|doc/*) EMOJI="📝";;
      chore/*) EMOJI="🔧";;
      refactor/*) EMOJI="♻️";;
      test/*|tests/*) EMOJI="✅";;
      style/*) EMOJI="💄";;
      release/*) EMOJI="🚀";;
      hotfix/*) EMOJI="🔥";;
      *) EMOJI="✨";;
    esac
    ;;
esac

# Prepend emoji + space to first line of commit message
sed -i "1s/^/${EMOJI} /" "$COMMIT_MSG_FILE"

exit 0
